FROM docker.io/cloudflare/sandbox:0.7.0

USER root

RUN apt-get update && apt-get install -y \
    nmap \
    netcat-openbsd \
    iproute2 \
    iputils-ping \
    dnsutils \
    curl \
    wget \
    git \
    vim \
    nano \
    hydra \
    john \
    sqlmap \
    hashcat \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    requests \
    beautifulsoup4 \
    scapy \
    cryptography \
    hashlib \
    colorama

USER sandbox
WORKDIR /workspace
